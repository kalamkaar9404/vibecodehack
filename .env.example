# MedSync AI — environment template. Copy to .env and fill in.
# The agents and the Next.js demo API both read GOOGLE_API_KEY / GEMINI_API_KEY.

# Gemini API key (https://aistudio.google.com/apikey). Used by ADK agents + UI.
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Use the Gemini API key path (not Vertex). Keep FALSE unless you wire full GCP auth.
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Model for all 3 agents
MEDSYNC_MODEL=gemini-2.5-flash

# Nasiko router LLM (point at Gemini for max "Google Tool Utilization" score)
ROUTER_LLM_PROVIDER=gemini
ROUTER_LLM_MODEL=gemini-2.5-flash
